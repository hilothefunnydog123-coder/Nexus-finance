{
  "manifest_version": 3,
  "name": "YN Copilot for TradingView",
  "version": "0.1.0",
  "description": "An AI trading copilot that lives in your browser and wakes up inside TradingView. Talk or type to it — it draws levels, points out key structure, and writes indicators.",
  "permissions": ["storage", "scripting", "activeTab", "tabs", "debugger"],
  "host_permissions": [
    "*://*.tradingview.com/*",
    "https://ynfinance.org/*",
    "http://localhost:3000/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html", "default_title": "YN Copilot for TradingView" },
  "commands": {
    "toggle-copilot": {
      "suggested_key": { "default": "Alt+Y" },
      "description": "Wake / sleep YN Copilot"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.tradingview.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
